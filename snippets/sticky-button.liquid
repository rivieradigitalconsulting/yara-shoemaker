{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign product_available_label = 'products.product.add_to_cart' | t
  if is_featured_product == true
    if product.template_suffix == 'preorder'
      assign product_available_label = 'products.product.preorder' | t
    endif
  elsif template.suffix == 'preorder' and request.design_mode or product.template_suffix == 'preorder'
    assign product_available_label = 'products.product.preorder' | t
  endif
-%}

{% if settings.general_riviera_styles and template.name == 'product' %}
  <div class="sticky-button__wrapper">
    <div class="sticky-button__inner">
      <div class="sticky-button__inner-bg">
        <label
          for="pdp-buy-button"
          class="bttn product-form__cart-submit"
          {% unless current_variant.available %}
            disabled="disabled"
          {% endunless %}
        >
          <span class="bttn__spinner">
            <svg
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              x="0px"
              y="0px"
              width="20px"
              height="20px"
              viewBox="0 0 50 50"
              style="enable-background:new 0 0 50 50;"
              xml:space="preserve"
            >
              <path fill="currentColor" d="M43.935,25.145c0-10.318-8.364-18.683-18.683-18.683c-10.318,0-18.683,8.365-18.683,18.683h4.068c0-8.071,6.543-14.615,14.615-14.615c8.072,0,14.615,6.543,14.615,14.615H43.935z">
                <animateTransform attributeType="xml"
                  attributeName="transform"
                  type="rotate"
                  from="0 25 25"
                  to="360 25 25"
                  dur="0.6s"
                  repeatCount="indefinite"/>
                </path>
            </svg>
          </span>

          <span>
            <span data-sold-out>{{ 'products.product.sold_out' | t }}</span>
            <span data-available>{{ product_available_label }}</span>
          </span>
        </label>
      </div>
    </div>
  </div>
{% endif %}
